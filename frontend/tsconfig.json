{
  "compilerOptions": {
    "allowImportingTsExtensions": true,          // ← это решает импорт .tsx без ошибки
    "noEmit": true,                               // vite сам компилирует
    "jsx": "react-jsx",
    "jsxImportSource": "react", // Для jsx-runtime
    "moduleResolution": "bundler",
    "module": "ESNext",
    "target": "ES2022",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "types": ["node"]          // ← добавь эту строку
  },
  "include": ["src", "vite.config.ts"]   // ← чтобы vite.config.ts тоже видел типы
}