{
  "compilerOptions": {
    "allowImportingTsExtensions": true,          // ← это решает импорт .tsx без ошибки
    "noEmit": true,                               // vite сам компилирует
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "module": "ESNext",
    "target": "ES2022",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src"]
}